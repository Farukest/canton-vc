# --------------------------------------------------------------------
# canton-vc issuer-demo — environment configuration
#
# Default mode is `mock` — zero-config, deterministic adapter, in-memory
# Canton mock. No credentials, no Canton participant needed. Just run:
#
#     pnpm --filter @canton-vc/example-issuer-demo start
#
# To exercise a real KYC vendor sandbox, set CANTON_VC_VENDOR to one of
# `didit`, `sumsub`, or `persona` and fill in the matching credentials
# below. Each vendor offers a free sandbox tier; this demo only ever
# calls the vendor's sandbox API, never their production API.
#
# Real on-chain Canton mint is OUT OF SCOPE for this demo (it uses an
# in-memory Canton mock). For a full mainnet/devnet mint round-trip,
# use scripts/live-*-canton-*-e2e.ts in the canton-vc repo root.
# --------------------------------------------------------------------

CANTON_VC_VENDOR=mock

# --------------------------------------------------------------------
# Didit (https://didit.me) — set CANTON_VC_VENDOR=didit to use
# --------------------------------------------------------------------
# DIDIT_API_KEY=
# DIDIT_KYC_WORKFLOW_ID=
# DIDIT_WEBHOOK_SECRET=
# DIDIT_BASE_URL=https://verification.didit.me

# --------------------------------------------------------------------
# Sumsub (https://sumsub.com) — set CANTON_VC_VENDOR=sumsub to use
# --------------------------------------------------------------------
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=
# SUMSUB_LEVEL_NAME_IDENTITY=basic-kyc-level
# SUMSUB_WEBHOOK_SECRET=
# SUMSUB_BASE_URL=https://api.sumsub.com

# --------------------------------------------------------------------
# Persona (https://withpersona.com) — set CANTON_VC_VENDOR=persona to use
# --------------------------------------------------------------------
# PERSONA_API_KEY=
# PERSONA_TEMPLATE_ID=
# PERSONA_WEBHOOK_SECRETS=
# PERSONA_BASE_URL=https://withpersona.com/api/v1
