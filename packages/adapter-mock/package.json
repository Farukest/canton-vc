{
  "name": "@canton-vc/adapter-mock",
  "version": "0.3.0",
  "description": "Deterministic mock KycProvider for testing and local development. Drop-in replacement for real adapters in CI, integration tests, and demo deployments. Approves, declines, or holds in review based on configurable rules.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "biome check src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@canton-vc/kyc-provider": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Farukest/canton-vc.git",
    "directory": "packages/adapter-mock"
  },
  "keywords": [
    "canton",
    "kyc",
    "mock",
    "testing",
    "canton-vc"
  ],
  "author": "Abdullah Faruk Özden <abdullahfarukozden@gmail.com> (https://github.com/Farukest)",
  "homepage": "https://github.com/Farukest/canton-vc/tree/main/packages/adapter-mock#readme",
  "bugs": {
    "url": "https://github.com/Farukest/canton-vc/issues"
  }
}
