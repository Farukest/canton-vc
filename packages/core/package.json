{
  "name": "@canton-vc/core",
  "version": "0.3.0",
  "description": "Canton V2 JSON Ledger client — pure protocol wire layer for the canton-vc reference implementation. Config + Zod request/response validation, command builders (mint / verify / revoke), party parsing, retry-aware fetch. No business logic, no DB dependency.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./explorer": {
      "types": "./src/explorer.ts",
      "default": "./src/explorer.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "biome check src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Farukest/canton-vc.git",
    "directory": "packages/core"
  },
  "keywords": [
    "canton",
    "canton-network",
    "daml",
    "ledger",
    "kyc",
    "verifiable-credentials",
    "vc",
    "identity"
  ],
  "author": "Abdullah Faruk Özden <abdullahfarukozden@gmail.com> (https://github.com/Farukest)",
  "homepage": "https://github.com/Farukest/canton-vc/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Farukest/canton-vc/issues"
  }
}
